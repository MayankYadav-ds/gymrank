generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UnitPreference {
  KG
  LB
}

enum SexCategory {
  MALE
  FEMALE
  OPEN
  PREFER_NOT_TO_SAY
}

enum ExerciseCategory {
  STRENGTH
  HYPERTROPHY
  BODYWEIGHT
  ACCESSORY
}

enum ExerciseDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MuscleRegion {
  FRONT
  BACK
  BOTH
}

enum MuscleTargetRole {
  PRIMARY
  SECONDARY
}

enum WorkoutStatus {
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum WorkoutSetType {
  NORMAL
  WARM_UP
  DROP_SET
  FAILURE
}

model User {
  id                          String         @id @default(cuid())
  email                       String         @unique
  passwordHash                String
  displayName                 String
  country                     String?
  unitPreference              UnitPreference @default(KG)
  dateOfBirth                 DateTime?
  sexCategory                 SexCategory?
  bodyweight                  Decimal?       @db.Decimal(6, 2)
  rankingParticipationEnabled Boolean        @default(false)
  workouts                    WorkoutSession[]
  personalRecords             PersonalRecord[]
  rankingSnapshots            RankingSnapshot[]
  achievements                 UserAchievement[]
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  @@index([country])
  @@index([sexCategory])
  @@index([rankingParticipationEnabled])
}

model Muscle {
  id        String           @id
  name      String
  region    MuscleRegion
  exercises ExerciseMuscle[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Exercise {
  id            String             @id
  name          String
  category      ExerciseCategory
  equipment     String
  difficulty    ExerciseDifficulty
  isTrackedLift Boolean            @default(false)
  trackedLiftId String?            @unique
  muscles       ExerciseMuscle[]
  workoutExercises WorkoutExercise[]
  personalRecords PersonalRecord[]
  rankingSnapshots RankingSnapshot[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([name])
  @@index([category])
  @@index([isTrackedLift])
}

model ExerciseMuscle {
  exerciseId String
  muscleId   String
  role       MuscleTargetRole

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  muscle   Muscle   @relation(fields: [muscleId], references: [id], onDelete: Restrict)

  @@id([exerciseId, muscleId])
  @@index([muscleId])
  @@index([role])
}

model WorkoutSession {
  id         String            @id @default(cuid())
  userId     String
  title      String?
  notes      String?
  status     WorkoutStatus     @default(IN_PROGRESS)
  startedAt  DateTime          @default(now())
  finishedAt DateTime?
  canceledAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([userId, startedAt])
  @@index([userId, status])
}

model WorkoutExercise {
  id               String         @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  orderIndex       Int
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  sets           WorkoutSet[]

  @@index([workoutSessionId, orderIndex])
  @@index([exerciseId])
}

model WorkoutSet {
  id                String         @id @default(cuid())
  workoutExerciseId String
  orderIndex        Int
  weight            Decimal        @db.Decimal(8, 2)
  reps              Int
  type              WorkoutSetType @default(NORMAL)
  completed         Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  personalRecord  PersonalRecord?

  @@index([workoutExerciseId, orderIndex])
}

model PersonalRecord {
  id               String   @id @default(cuid())
  userId           String
  exerciseId       String
  workoutSessionId String
  workoutSetId     String   @unique
  weight           Decimal  @db.Decimal(8, 2)
  reps             Int
  achievedAt       DateTime
  createdAt        DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  workoutSet  WorkoutSet @relation(fields: [workoutSetId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseId, achievedAt])
  @@index([userId, achievedAt])
}

model RankingSnapshot {
  id          String   @id @default(cuid())
  userId      String
  exerciseId  String
  bestWeight  Decimal  @db.Decimal(8, 2)
  bestReps    Int
  currentRank Int
  percentile  Decimal  @db.Decimal(5, 2)
  achievedAt  DateTime
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@unique([userId, exerciseId])
  @@index([exerciseId, currentRank])
  @@index([exerciseId, bestWeight, bestReps, achievedAt])
  @@index([userId])
}

model Achievement {
  id               String            @id
  code             String            @unique
  title            String
  description      String
  category         String
  icon             String
  rarity           String
  hidden           Boolean           @default(false)
  userAchievements UserAchievement[]
  createdAt        DateTime          @default(now())

  @@index([category])
  @@index([rarity])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}
